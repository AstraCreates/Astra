FROM python:3.13-slim

RUN pip install --no-cache-dir "headroom-ai[proxy]"

EXPOSE 8787

# mode=token + no-ccr-inject-tool: confirmed via live A/B against real OpenRouter
# traffic to cut prompt tokens ~70% with no retrieve round-trip (CCR's default
# retrieve-tool path didn't reliably resolve in testing — avoid it).
CMD ["headroom", "proxy", "--host", "0.0.0.0", "--port", "8787", \
     "--mode", "token", "--no-ccr-inject-tool", \
     "--openai-api-url", "https://openrouter.ai/api/v1"]
