FROM python:3.13-slim

RUN pip install --no-cache-dir "headroom-ai[proxy]"

EXPOSE 8787

# Token mode keeps the proxy focused on prompt reduction. The installed
# headroom-ai release no longer exposes the old CCR injection flag.
CMD ["headroom", "proxy", "--host", "0.0.0.0", "--port", "8787", \
     "--mode", "token", \
     "--openai-api-url", "https://openrouter.ai/api/v1"]
