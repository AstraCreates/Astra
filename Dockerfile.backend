FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential ca-certificates curl git gnupg sudo \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
       | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
       > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    nodejs \
    libjpeg-dev zlib1g-dev libpng-dev libwebp-dev libfreetype6-dev \
    && rm -rf /var/lib/apt/lists/* \
    && RTK_INSTALL_DIR=/usr/local/bin sh -c "$(curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh)" \
    && mkdir -p /opt/rtk-shims \
    && printf '%s\n' '#!/bin/sh' 'exec /usr/local/bin/rtk git "$@"' > /opt/rtk-shims/git \
    && printf '%s\n' '#!/bin/sh' 'exec /usr/local/bin/rtk cat "$@"' > /opt/rtk-shims/cat \
    && chmod +x /opt/rtk-shims/git /opt/rtk-shims/cat \
    && npm install -g @gitlawb/openclaude 2>/dev/null || true \
    && npm install -g @juliusbrussee/caveman-code 2>/dev/null || true \
    && useradd -m -s /bin/bash astra \
    && echo "astra ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers \
    && mkdir -p /home/astra/.openclaude && chown astra:astra /home/astra/.openclaude

COPY requirements.txt .
# setuptools/wheel are needed to build sdist-only deps (e.g. pyarrow); newer pip
# no longer bundles pkg_resources, so install them explicitly first.
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements.txt && \
    playwright install chromium && \
    playwright install-deps chromium
# Astra supplies the search worker through Company OS MCP, so Open Deep
# Research's optional provider integrations are intentionally not installed.
RUN pip install --no-cache-dir --no-deps git+https://github.com/langchain-ai/open_deep_research.git
# Headroom is an optional proxy add-on; the application dependencies above are
# mandatory and must fail the image build when resolution or installation fails.
RUN pip install --no-cache-dir headroom-ai==0.26.0 "transformers>=4.53.0" || true

COPY . .

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

EXPOSE 8000

# Worker count is env-driven (WEB_CONCURRENCY, default 1). Running >1 worker
# requires ASTRA_MULTIWORKER=1 so the SSE fan-out and kill switch use Redis
# (cross-worker) instead of in-process state.
CMD ["sh", "-c", "uvicorn backend.main:app --host 0.0.0.0 --port 8000 --workers ${WEB_CONCURRENCY:-1}"]
