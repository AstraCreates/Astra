SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=your-gemini-key
AGENT_MODEL_BASE_URL=http://localhost:8080/v1
AGENT_MODEL_API_KEY=dummy
AGENT_MODEL_NAME=gemma4
PLANNER_MODEL_BASE_URL=http://localhost:8080/v1
PLANNER_MODEL_API_KEY=dummy
PLANNER_MODEL_NAME=planner-model
CHAT_MODEL_BASE_URL=http://localhost:8080/v1
CHAT_MODEL_API_KEY=dummy
CHAT_MODEL_NAME=chat-model
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1

# Stripe Standard Connect — register at https://dashboard.stripe.com/settings/connect
# STRIPE_SECRET_KEY: your platform secret key (sk_live_... or sk_test_...)
# STRIPE_CLIENT_ID:  your Connect client ID (ca_...)
# BACKEND_URL:       public URL of this backend (for OAuth redirect)
# FRONTEND_URL:      public URL of the frontend (for post-OAuth redirect)
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SCALE=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3003
# ASTRA_CORS_ORIGINS: comma-separated allow-list of origins permitted to call this API
# from a browser (CORSMiddleware). Never set to "*" — header-based auth
# (x-astra-user-id) makes a wildcard origin a cross-site account takeover.
ASTRA_CORS_ORIGINS=http://localhost:3000
DESKTOP_DOWNLOAD_URL=
DESKTOP_DMG_PATH=

# Production auth/admin controls
ASTRA_REQUIRE_AUTH=false
ASTRA_PLATFORM_ADMINS=
ASTRA_JWT_JWKS_URL=
ASTRA_JWT_SECRET=
ASTRA_TRUST_AUTH_HEADERS=false
ASTRA_CREDS_KEY=
ASTRA_ALERT_WEBHOOK_URL=
ASTRA_RUNTIME_GUARDRAILS=true
ASTRA_TOOL_REGISTRY_V2=false
ASTRA_SPECIALIST_MANIFESTS=false
ASTRA_NATIVE_TOOL_CALLS=false
ASTRA_CONTEXT_COMPRESSION_V2=false
ASTRA_DELEGATION_V2=false
ASTRA_SKILL_REVIEW=false
ASTRA_NATIVE_TOOL_CALLS_ROLLOUT_PERCENT=100
ASTRA_CONTEXT_COMPRESSION_V2_ROLLOUT_PERCENT=100
ASTRA_DELEGATION_V2_ROLLOUT_PERCENT=100
ASTRA_SKILL_REVIEW_ROLLOUT_PERCENT=100
ASTRA_FALLBACK_MODEL=xiaomi/mimo-v2.5
ASTRA_SHADOW_RUNTIME=false

# Production connector tokens used by --seed-env-connectors
GITHUB_TOKEN=
VERCEL_TOKEN=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NOTION_TOKEN=
NOTION_OPERATING_PARENT_ID=
SENDGRID_API_KEY=

# NWRA LLC filing — Astra's company card (pays for founder's LLC filing fee)
NWRA_CARD_NUMBER=
NWRA_CARD_EXPIRY_MONTH=
NWRA_CARD_EXPIRY_YEAR=
NWRA_CARD_CVV=
NWRA_CARD_NAME=
NWRA_BILLING_ADDRESS=
NWRA_BILLING_CITY=
NWRA_BILLING_STATE=
NWRA_BILLING_ZIP=

# Composio — OAuth for Gmail, LinkedIn, Twitter, GitHub PRs, Linear, Calendar, Notion
# Get key at https://app.composio.dev/settings
COMPOSIO_API_KEY=

# E2E provisioning verification inbox
TEST_EMAIL_BASE=
TEST_EMAIL_IMAP_PASSWORD=
TEST_EMAIL_WEB_PASSWORD=
